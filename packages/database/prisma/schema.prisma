generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(uuid())
  mobile         String           @unique
  name           String?
  isVerified     Boolean          @default(false)
  isAgeCertified Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  otpLogs        OtpLog[]
  wallet         Wallet?
  kyc            KycVerification?
  userPromos     UserPromo[]
  refreshTokens  RefreshToken[]
}

model OtpLog {
  id        String   @id @default(uuid())
  userId    String
  otpHash   String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
}

model Wallet {
  id              String        @id @default(uuid())
  userId          String        @unique
  depositBalance  Decimal       @default(0) @db.Decimal(12, 2)
  winningsBalance Decimal       @default(0) @db.Decimal(12, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  transactions    Transaction[]
}

model Transaction {
  id          String              @id @default(uuid())
  walletId    String
  userId      String
  type        TransactionType
  category    TransactionCategory
  amount      Decimal             @db.Decimal(12, 2)
  referenceId String?
  description String?
  createdAt   DateTime            @default(now())
  wallet      Wallet              @relation(fields: [walletId], references: [id])
  @@index([userId])
  @@index([walletId])
  @@index([createdAt])
}

model KycVerification {
  id              String    @id @default(uuid())
  userId          String    @unique
  aadhaarNumber   String?   // Last 4 digits
  otpTxnId        String?
  aadhaarRefId    String?
  verifiedName    String?
  verifiedDob     String?
  verifiedGender  String?
  verifiedAddress String?
  status          KycStatus @default(PENDING)
  documentUrl     String?
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
}

model PromoCode {
  id              String      @id @default(uuid())
  code            String      @unique
  discountPercent Decimal     @db.Decimal(5, 2)
  maxBonus        Decimal     @db.Decimal(12, 2)
  minDeposit      Decimal     @db.Decimal(12, 2)
  usageLimit      Int
  usedCount       Int         @default(0)
  validUntil      DateTime
  createdAt       DateTime    @default(now())
  userPromos      UserPromo[]
}

model UserPromo {
  id      String    @id @default(uuid())
  userId  String
  promoId String
  usedAt  DateTime  @default(now())
  user    User      @relation(fields: [userId], references: [id])
  promo   PromoCode @relation(fields: [promoId], references: [id])
  @@unique([userId, promoId])
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionCategory {
  DEPOSIT
  WITHDRAWAL
  WINNING
  PARTICIPATION
  BONUS
}

enum KycStatus {
  PENDING
  OTP_SENT
  VERIFIED
  REJECTED
}
